.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: #f7f3ef;
}

.user-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f0f0f0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar.default {
  background: linear-gradient(135deg, #efc379, #d9953f);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.scene-btn {
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  background: #ffffff;
  border: 1rpx solid #ead9bf;
  color: #7d5e2e;
  font-size: 20rpx;
}

.user-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.user-tip {
  font-size: 22rpx;
  color: #999;
}

.user-actions {
  margin-top: 8rpx;
  display: flex;
  gap: 8rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.mode-selector {
  display: flex;
  gap: 16rpx;
}

.mode-item {
  flex: 1;
  padding: 18rpx;
  border-radius: 10rpx;
  border: 2rpx solid #e0e0e0;
  background: #f9f9f9;
  text-align: center;
  transition: all 0.3s;
}

.mode-item.active {
  border-color: #d9953f;
  background: linear-gradient(135deg, rgba(239, 195, 121, 0.18), rgba(217, 149, 63, 0.1));
}

.mode-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.mode-item.active .mode-text {
  color: #d9953f;
  font-weight: bold;
}

.form-item {
  margin-bottom: 10rpx;
}

.form-label {
  font-size: 23rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.form-picker {
  width: 100%;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #333;
}

.picker {
  flex: 1;
}

.picker-arrow {
  font-size: 36rpx;
  color: #999;
  margin-left: 16rpx;
}

.chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.chip-btn {
  padding: 8rpx 14rpx;
  border-radius: 10rpx;
  background: #f3f3f3;
  border: 1rpx solid #e8e8e8;
}

.chip-btn.active {
  background: #f8ead1;
  border-color: #e4c38f;
}

.chip-btn-text {
  font-size: 22rpx;
  color: #6d532e;
}

.inline-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.inline-label {
  margin-bottom: 0;
  min-width: 120rpx;
  flex-shrink: 0;
}

.inline-chip-group {
  flex: 1;
}

.inline-picker {
  flex: 1;
  margin-top: 0;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.stat-section {
  background: #f9f9f9;
  border-radius: 10rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
}

.stat-section:last-child {
  margin-bottom: 0;
}

.stat-header {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.stat-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.no-data {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

.record-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.quick-no-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-no-item {
  min-width: 78rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f2f2f2;
  color: #666;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-no-item.selected {
  background: rgba(246, 183, 60, 0.2);
  color: #d38700;
  font-weight: 600;
}

.record-item {
  background: #f9f9f9;
  border-radius: 10rpx;
  padding: 12rpx;
  margin-bottom: 8rpx;
  position: relative;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.record-item.selected {
  border-color: #d9953f;
  background: linear-gradient(135deg, rgba(239, 195, 121, 0.14), rgba(217, 149, 63, 0.05));
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.record-no {
  font-size: 22rpx;
  color: #999;
}

.record-type {
  font-size: 24rpx;
  font-weight: bold;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.record-type.buy {
  color: #ff5252;
  background: rgba(255, 82, 82, 0.1);
}

.record-type.sell {
  color: #4caf50;
  background: rgba(76, 175, 80, 0.1);
}

.record-date {
  font-size: 20rpx;
  color: #999;
}

.record-body {
  display: flex;
  justify-content: space-between;
}

.record-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.record-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
  margin-top: 10rpx;
}

.action-btn {
  font-size: 22rpx;
  line-height: 1;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  border: none;
  background: #ececec;
  color: #666;
}

.action-btn.danger {
  background: rgba(255, 82, 82, 0.12);
  color: #ff5252;
}

.info-label {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 3rpx;
}

.info-value {
  font-size: 23rpx;
  color: #333;
  font-weight: 500;
}

.record-check {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 36rpx;
  height: 36rpx;
  background: #d9953f;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.btn {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  background: linear-gradient(135deg, #efc379, #d9953f);
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: bold;
  text-align: center;
}

.btn.mini {
  height: 64rpx;
  line-height: 64rpx;
  font-size: 22rpx;
  width: 240rpx;
}

.btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn.secondary {
  background: #e0e0e0;
  color: #666;
}

.edit-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 99;
}

.edit-card {
  width: 88%;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}