.container {
  min-height: 100vh;
  padding: 20rpx;
  background: #f7f3ef;
}

.tip {
  padding: 10rpx 12rpx;
  background: #fff7ed;
  color: #9a3412;
  border-radius: 10rpx;
  font-size: 21rpx;
}

.card {
  margin-top: 10rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 12rpx;
}

.inline-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.inline-label {
  font-size: 20rpx;
  color: #666;
  min-width: 100rpx;
}

.inline-picker-wrap {
  flex: 1;
}

.input,
.picker {
  width: 100%;
  background: #f5f5f5;
  border-radius: 10rpx;
  min-height: 64rpx;
  line-height: 36rpx;
  padding: 12rpx;
  box-sizing: border-box;
  margin-bottom: 8rpx;
}

.btn,
.cancel-btn {
  border-radius: 10rpx;
  min-height: 66rpx;
  line-height: 66rpx;
  font-size: 22rpx;
}

.btn {
  background: linear-gradient(135deg, #efc379, #d9953f);
  color: #fff;
}

.cancel-btn {
  margin-top: 8rpx;
  background: #fee2e2;
  color: #991b1b;
}

.drag-hint {
  margin-top: 8rpx;
  color: #1d4ed8;
  font-size: 21rpx;
}

.empty {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 21rpx;
}

.task {
  margin-top: 8rpx;
  background: #fff;
  border-radius: 10rpx;
  padding: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8rpx;
}

.left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 8rpx;
  border: 2rpx solid #94a3b8;
  line-height: 30rpx;
  text-align: center;
  color: #fff;
}

.check.checked {
  background: #10b981;
  border-color: #10b981;
}

.title {
  font-size: 24rpx;
  color: #0f172a;
}

.title.done {
  color: #94a3b8;
  text-decoration: line-through;
}

.meta {
  font-size: 20rpx;
  color: #64748b;
}

.delete {
  color: #b91c1c;
  font-size: 21rpx;
}
